# Copy this file to .env and fill in the values before running the app

# MySQL connection - user/password/host/port/database
DATABASE_URL="mysql://asset3d_app:your_password@localhost:3306/asset3d_db"

# Server settings
PORT=3000
BASE_URL=http://localhost:3000

# JWT and security
JWT_SECRET=change_this_dev_secret
JWT_AUDIENCE=asset3d-clients

# Email transport (SMTP). If not set, a JSON transport will be used and verify links will be logged
# SMTP_USER=username
# SMTP_PASS=password
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587

NODE_ENV=development
DATABASE_URL="file:./prisma/dev.db"
PORT=3000
BASE_URL=http://localhost:3000
JWT_SECRET=change_this_dev_secret
JWT_AUDIENCE=asset3d-clients
EMAIL_FROM=no-reply@example.com
NODE_ENV=development

# Optional: configure real SMTP if available
# EMAIL_TRANSPORT_URL=smtp://user:pass@smtp.example.com:587
